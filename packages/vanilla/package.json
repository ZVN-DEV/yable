{
  "name": "@zvndev/yable-vanilla",
  "version": "0.1.0",
  "description": "Vanilla JS/DOM renderer for @zvndev/yable-core -- framework-free table rendering",
  "keywords": ["table", "data-grid", "datagrid", "vanilla", "javascript", "dom", "renderer"],
  "license": "MIT",
  "author": "ZVN DEV",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZVN-DEV/yable.git",
    "directory": "packages/vanilla"
  },
  "homepage": "https://github.com/ZVN-DEV/yable#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@zvndev/yable-core": "workspace:*"
  },
  "peerDependencies": {
    "@zvndev/yable-themes": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@zvndev/yable-themes": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "typescript": "^5.7.0"
  }
}
