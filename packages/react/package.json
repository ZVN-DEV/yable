{
  "name": "@zvndev/yable-react",
  "version": "0.1.0",
  "description": "React adapter for @zvndev/yable-core -- components, hooks, and form controls for building data tables",
  "keywords": ["react", "table", "data-grid", "datagrid", "components", "hooks", "typescript", "editing"],
  "license": "MIT",
  "author": "ZVN DEV",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZVN-DEV/table.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/ZVN-DEV/table#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@zvndev/yable-core": "workspace:*"
  },
  "peerDependencies": {
    "@chenglou/pretext": ">=0.0.4",
    "@zvndev/yable-themes": "workspace:*",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@chenglou/pretext": {
      "optional": true
    },
    "@zvndev/yable-themes": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
